{
    "targets": {
        "debug": {
            "outFile": "build/QuestTracker.wasm",
            "textFile": "build/QuestTracker.wat",
            "use": ["abort=src/index/abort"]
        },
        "staking": {
            "outFile": "build/StakingQuest.wasm",
            "textFile": "build/StakingQuest.wat",
            "use": ["abort=src/index-staking/abort"]
        },
        "vault": {
            "outFile": "build/VaultQuest.wasm",
            "textFile": "build/VaultQuest.wat",
            "use": ["abort=src/index-vault/abort"]
        }
    },
    "options": {
        "transform": "@btc-vision/opnet-transform",
        "sourceMap": false,
        "optimizeLevel": 3,
        "shrinkLevel": 1,
        "converge": true,
        "noAssert": false,
        "enable": [
            "sign-extension",
            "mutable-globals",
            "nontrapping-f2i",
            "bulk-memory",
            "simd",
            "reference-types",
            "multi-value"
        ],
        "runtime": "stub",
        "memoryBase": 0,
        "initialMemory": 1,
        "exportStart": "start"
    }
}
